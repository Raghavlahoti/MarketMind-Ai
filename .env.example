# ============================================================================
# MARKETMIND AI - BACKEND ENVIRONMENT VARIABLES CONFIGURATION
# ============================================================================

# App Settings
APP_NAME="MarketMind AI"
ENV="development" # development, staging, production
DEBUG=True
PORT=8000
HOST="0.0.0.0"

# Security (JWT Authentication)
# Generate a secure secret using: openssl rand -hex 32
JWT_SECRET_KEY="replace-this-with-a-cryptographically-secure-hex-string-for-prod"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database Configurations (PostgreSQL / Supabase Connection Pool)
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/marketmind_ai"

# Vector Database (Qdrant Client Setup)
QDRANT_HOST="localhost"
QDRANT_PORT=6333
QDRANT_API_KEY="" # Required if connecting to Qdrant Cloud

# NVIDIA NIM (Inference Microservice API Keys & Base URLs)
NVIDIA_API_KEY="nvapi-replace-with-your-actual-nvidia-nim-developer-api-key"
NVIDIA_NIM_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_LLM_MODEL="nvidia/llama-3.1-instruct-70b"

# Embeddings Engine
EMBEDDING_PROVIDER="openai" # openai, local, nim
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSION=1536
OPENAI_API_KEY="" # Required if using OpenAI for embeddings
